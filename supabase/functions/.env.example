# Variables de entorno para las Edge Functions de AdjusterPro
# Configurar en: Supabase Dashboard → Edge Functions → Manage secrets

# URL pública del frontend (sin slash final)
APP_URL=https://tu-dominio.com

# Correo del administrador que recibe las solicitudes de aprobación
ADMIN_EMAIL=admin@ejemplo.com

# Correo remitente (debe estar verificado en Resend)
FROM_EMAIL=noreply@tu-dominio.com

# API Key de Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Las siguientes son inyectadas automáticamente por Supabase — no configurar manualmente:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY
